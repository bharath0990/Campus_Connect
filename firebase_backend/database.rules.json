{
  "rules": {
    "chats": {
      "$chatRoomId": {
        ".read": "auth != null && (data.child('participants').child(auth.uid).exists() || !data.exists())",
        ".write": "auth != null && (data.child('participants').child(auth.uid).exists() || !data.exists() || newData.child('participants').child(auth.uid).exists())",
        "messages": {
          "$messageId": {
            ".read": "auth != null",
            ".write": "auth != null && newData.hasChildren(['senderId', 'text', 'timestamp', 'senderName'])"
          }
        }
      }
    }
  }
}
